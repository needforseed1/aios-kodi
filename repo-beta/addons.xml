<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
  <addon id="plugin.video.aiostreams" name="AIOStreams for Kodi" version="0.1.92" provider-name="OpenCode">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Browse metadata catalogs and play AIOStreams sources</summary>
      <description lang="en_GB">Kodi bridge for AIOMetadata or Cinemeta catalogs/search/metadata and AIOStreams stream links.</description>
      <platform>all</platform>
      <license>GPL-3.0</license>
      <assets>
        <icon>resources/media/icon.png</icon>
        <fanart>resources/media/search_default_landscape_v2.png</fanart>
      </assets>
    </extension>
  </addon>
  <addon id="repository.aiostreams.beta" name="AIOStreams Beta Repository" version="0.1.0" provider-name="OpenCode">
    <requires>
      <import addon="xbmc.addon" version="12.0.0" />
    </requires>
    <extension point="xbmc.addon.repository" name="AIOStreams Beta Repository">
      <dir>
        <info compressed="false">https://needforseed1.github.io/aios-kodi/beta/addons.xml</info>
        <checksum>https://needforseed1.github.io/aios-kodi/beta/addons.xml.md5</checksum>
        <datadir zip="true">https://needforseed1.github.io/aios-kodi/beta/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en_GB">Install beta updates for AIOStreams for Kodi</summary>
      <description lang="en_GB">Opt-in beta repository for preview AIOStreams for Kodi builds.</description>
      <platform>all</platform>
      <license>GPL-3.0</license>
      <assets>
        <icon>icon.png</icon>
      </assets>
    </extension>
  </addon>
</addons>
